[Unit]
Description=nodejs app

[Service]
ExecStart=/opt/node/bin/npm start /opt/app/app.js
Restart=always
User=root
Environment=PATH=/opt/node/bin:/usr/bin:/usr/local/bin
Environment=NODE_ENV=production
WorkingDirectory=/opt/app
SyslogIdentifier=nodeapp
TimeoutSec=30
Restart=on-failure
RestartSec=30
StartLimitInterval=350
StartLimitBurst=10

[Install]
WantedBy=multi-user.target
